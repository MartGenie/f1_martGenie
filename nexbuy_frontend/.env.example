PORT=8001

# Public API base for browser REST requests.
NEXT_PUBLIC_API_BASE_URL=/api

# Used by Next rewrites on the frontend server.
BACKEND_ORIGIN=http://127.0.0.1:8000

# Used by browser-side SSE connections for chat and negotiation streams.
NEXT_PUBLIC_BACKEND_ORIGIN=http://127.0.0.1:8000

# real | mock
NEXT_PUBLIC_CHAT_MODE=real
